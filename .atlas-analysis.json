  "keyFeatures": [
    "Reward calculator for specific spend amounts and Merchant Category Codes (MCCs)",
    "Best card finder to compare multiple cards across a transaction",
    "Transfer partner calculator for airline/hotel loyalty points",
    "MCC lookup tool to identify merchant category codes",
    "My Cards portfolio to track and manage owned credit cards",
    "Multi-region support for India and Singapore",
    "Firebase Authentication with Google Sign-in and anonymous mode",
    "Dark mode and responsive design",
    "Mobile apps available on iOS and Android",
    "Rate-limited API with usage tracking"
  ],
  "publicApiSurface": [
    "GET /v4/bank?country={region}",
    "GET /v4/card?bank={bank}&country={region}",
    "GET /v4/mcc?search={query}",
    "GET /v4/cardQuestions?bank={bank}&card={card}",
    "POST /v4/calculateRewards",
    "POST /v4/bestCardQuestions",
    "POST /v4/calculateBestCard",
    "POST /v4/transfer",
    "GET /v4/card/detail?bank={bank}&card={card}&country={region}",
    "GET /v4/goals?bank={bank}&card={card}&country={region}",
    "GET /v4/user/cards",
    "POST /v4/user/cards",
    "PATCH /v4/user/cards",
    "DELETE /v4/user/cards",
    "PUT /v4/user/cards"
  ]
